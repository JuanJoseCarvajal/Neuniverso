# Environment Variables for NEUNIVERSO

# Application
NODE_ENV=production
NEXTAUTH_URL=https://neuniverso.com
NEXTAUTH_SECRET=your-secret-key-here-min-32-chars

# Database
DB_PASSWORD=changeme123
DATABASE_URL=postgresql://neuniverso:changeme123@db:5432/neuniverso_db

# Redis
REDIS_PASSWORD=changeme123
REDIS_URL=redis://:changeme123@redis:6379

# Third-party APIs (Add your own)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Email/SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@neuniverso.com

# Other configurations
PORT=3000
HOSTNAME=0.0.0.0
